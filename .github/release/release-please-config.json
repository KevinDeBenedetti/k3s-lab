{
  "packages": {
    ".": {
      "release-type": "simple",
      "changelog-path": "CHANGELOG.md",
      "include-v-tag": true,
      "bump-minor-pre-major": true,
      "bump-patch-for-minor-pre-major": false,
      "extra-files": [
        { "type": "yaml", "path": "charts/platform-argocd/Chart.yaml", "jsonpath": "$.version" },
        { "type": "yaml", "path": "charts/platform-base/Chart.yaml", "jsonpath": "$.version" },
        { "type": "yaml", "path": "charts/platform-monitoring/Chart.yaml", "jsonpath": "$.version" },
        { "type": "yaml", "path": "charts/platform-security/Chart.yaml", "jsonpath": "$.version" },
        { "type": "yaml", "path": "charts/platform-cert-manager/Chart.yaml", "jsonpath": "$.version" },
        { "type": "yaml", "path": "charts/platform-external-secrets/Chart.yaml", "jsonpath": "$.version" },
        { "type": "yaml", "path": "charts/platform-traefik/Chart.yaml", "jsonpath": "$.version" },
        { "type": "yaml", "path": "charts/platform-vault/Chart.yaml", "jsonpath": "$.version" },
        { "type": "generic", "path": "lib/script-init.sh" },
        { "type": "generic", "path": "lib/run-mode.sh" },
        { "type": "generic", "path": "scripts/vault-init.sh" },
        { "type": "generic", "path": "scripts/vault-configure.sh" },
        { "type": "generic", "path": "scripts/vault-seed-cloudflare.sh" },
        { "type": "generic", "path": "scripts/uninstall.sh" },
        { "type": "generic", "path": "scripts/generate-inventory.sh" },
        { "type": "generic", "path": "scripts/deploy-grafana-oauth.sh" },
        { "type": "generic", "path": "scripts/get-kubeconfig.sh" }
      ]
    }
  },
  "git-user-name": "github-actions[bot]",
  "git-user-email": "github-actions[bot]@users.noreply.github.com",
  "changelog-path": "CHANGELOG.md",
  "release-type": "simple"
}
