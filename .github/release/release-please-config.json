{
  "packages": {
    ".": {
      "release-type": "simple",
      "changelog-path": "CHANGELOG.md",
      "include-v-tag": true,
      "bump-minor-pre-major": true,
      "bump-patch-for-minor-pre-major": false,
      "extra-files": [
        { "type": "yaml", "path": "charts/platform-argocd/Chart.yaml", "jsonpath": "$.version" },
        { "type": "yaml", "path": "charts/platform-base/Chart.yaml", "jsonpath": "$.version" },
        { "type": "yaml", "path": "charts/platform-monitoring/Chart.yaml", "jsonpath": "$.version" },
        { "type": "yaml", "path": "charts/platform-security/Chart.yaml", "jsonpath": "$.version" },
        { "type": "yaml", "path": "charts/platform-vault/Chart.yaml", "jsonpath": "$.version" }
      ]
    }
  },
  "git-user-name": "github-actions[bot]",
  "git-user-email": "github-actions[bot]@users.noreply.github.com",
  "changelog-path": "CHANGELOG.md",
  "release-type": "simple"
}
