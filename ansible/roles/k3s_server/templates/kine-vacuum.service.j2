[Unit]
Description=Reclaim disk space from k3s kine SQLite datastore (VACUUM)
Documentation=https://github.com/k3s-io/kine
# Don't race cluster startup
After=network-online.target k3s.service
Wants=network-online.target

[Service]
Type=oneshot
ExecStart=/usr/local/sbin/kine-vacuum.sh
# VACUUM can briefly use CPU/IO; be a good citizen
Nice=10
IOSchedulingClass=best-effort
IOSchedulingPriority=7
# Log cleanly to journal
StandardOutput=journal
StandardError=journal
