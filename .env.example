# =============================================================================
# .env.example — copy to .env and fill in your values
# ⚠️  NEVER commit .env to git (it is in .gitignore)
# =============================================================================

# --- VPS nodes ---
SERVER_IP=1.2.3.4           # Public IP of the server (control-plane) VPS
AGENT_IP=5.6.7.8            # Public IP of the agent VPS

# --- SSH ---
SSH_USER=debian              # SSH user AFTER bootstrap (regular user, not root)
SSH_KEY=~/.ssh/id_ed25519   # Path to your private key
INITIAL_USER=root            # User for the first connection (before bootstrap)

# --- k3s ---
K3S_VERSION=v1.32.2+k3s1    # Pinned k3s version — must match on server & agent
K3S_NODE_TOKEN=              # Filled automatically after server install

# --- Helm chart versions (used by deploy-stack.sh) ---
TRAEFIK_CHART_VERSION=39.0.7
CERT_MANAGER_VERSION=v1.17.1
KUBE_PROMETHEUS_VERSION=82.10.3
LOKI_VERSION=6.35.1
PROMTAIL_VERSION=6.17.1

# --- Application ---
DOMAIN=example.com              # Primary domain (e.g. for apps: app.example.com)
EMAIL=admin@example.com         # Let's Encrypt registration email

# --- Traefik Dashboard ---
DASHBOARD_DOMAIN=dashboard.example.com  # Traefik dashboard domain
DASHBOARD_PASSWORD=                     # BasicAuth password (htpasswd-hashed by make deploy-dashboard-secret)

# --- Grafana (monitoring) ---
GRAFANA_DOMAIN=grafana.example.com      # Grafana domain
GRAFANA_PASSWORD=                       # Grafana admin password (set before make deploy-grafana-secret)

# --- ArgoCD (GitOps CD — see makefiles/52-argocd.mk) ---
ARGOCD_VERSION=7.8.26                           # Pin ArgoCD Helm chart version
ARGOCD_DOMAIN=argocd.example.com                # ArgoCD UI domain (VPN-only for UI/gRPC, webhook is public)
ARGOCD_REPO_URL=git@github.com:you/infra.git    # Git repo to register in ArgoCD
# ADMIN_EMAIL=you@example.com                   # Only this email gets admin access (ArgoCD RBAC + Grafana OAuth)

# --- OIDC provider (optional — used by vault-seed for ArgoCD + Grafana OAuth) ---
# OIDC_PROVIDER_NAME=MyProvider                 # Display name (e.g. "Infomaniak", "Google")
# OIDC_CLIENT_ID=                               # OAuth2 client ID
# OIDC_CLIENT_SECRET=                           # OAuth2 client secret
# OIDC_ISSUER_URL=https://auth.example.com      # OIDC discovery/issuer URL (used by Vault OIDC)
# OIDC_AUTH_URL=https://auth.example.com/authorize
# OIDC_TOKEN_URL=https://auth.example.com/token
# OIDC_API_URL=https://auth.example.com/userinfo

# --- Kubeconfig ---
KUBECONFIG_CONTEXT=k3s-lab # kubectl context name created by get-kubeconfig.sh

# --- k3s networking (optional) ---
# FLANNEL_BACKEND=vxlan       # CNI backend: vxlan (default) or wireguard-native
# WG_PORT=51820               # If set, opens this UDP port in UFW during server install (for admin VPN)

# --- WireGuard admin VPN (optional — see makefiles/35-wireguard.mk) ---
# WG_SERVER_IP=10.8.0.1      # Server tunnel IP
# WG_SUBNET=10.8.0.0/24      # VPN subnet CIDR
# WG_CLIENT_IP=10.8.0.2      # Client tunnel IP
# WG_PEER_NAME=laptop         # Human-readable peer label
# WG_VPN_DOMAINS=vault.example.com argocd.example.com  # Domains resolved via VPN (PostUp /etc/hosts)

# --- Vault + ESO (optional — see makefiles/55-vault.mk + docs/stack/vault.md) ---
# VAULT_DOMAIN=vault.example.com    # Vault UI domain (VPN-only)
# VAULT_CHART_VERSION=0.29.1        # Pin Vault Helm chart version
# ESO_CHART_VERSION=0.14.3          # Pin External Secrets Operator chart version
# VAULT_ROOT_TOKEN=                 # Root token — set after make vault-init (never commit)
# VAULT_UNSEAL_KEY_1=               # Unseal key 1 — needed after node reboot (never commit)
# VAULT_UNSEAL_KEY_2=               # Unseal key 2 — needed after node reboot (never commit)
